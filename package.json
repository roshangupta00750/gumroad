{
  "name": "gumroad",
  "version": "1.0.0",
  "description": "NPM Packages for Gumroad",
  "main": "build.js",
  "license": "UNLICENSED",
  "directories": {
    "doc": "doc"
  },
  "engines": {
    "node": "~22.22.0"
  },
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@ai-sdk/react": "^2.0.8",
    "@anycable/web": "^1.1.0",
    "@boxicons/react": "^1.0.2",
    "@inertiajs/react": "^2.3.13",
    "@paypal/paypal-js": "^8.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "@rails/activestorage": "^7.1.3",
    "@stripe/react-stripe-js": "^2.0.0",
    "@stripe/stripe-js": "^4.0.0",
    "@tiptap/core": "2.6.5",
    "@tiptap/extension-character-count": "2.6.5",
    "@tiptap/extension-code-block-lowlight": "2.6.5",
    "@tiptap/extension-link": "2.6.5",
    "@tiptap/extension-placeholder": "2.6.5",
    "@tiptap/extension-underline": "2.6.5",
    "@tiptap/pm": "2.6.5",
    "@tiptap/react": "2.6.5",
    "@tiptap/starter-kit": "2.6.5",
    "autolinker": "^4.0.0",
    "braintree-web": "^3.88.6",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.3.2",
    "clipboard": "^2.0.11",
    "clsx": "^2.1.1",
    "date-fns": "^3.0.0",
    "date-fns-tz": "^3.0.0",
    "dompurify": "^3.4.0",
    "fast-average-color": "^9.4.0",
    "immer": "^10.0.0",
    "jquery": "^3.6.3",
    "js-yaml": "^4.1.0",
    "json-schema-to-ts": "^3.0.0",
    "libphonenumber-js": "^1.12.23",
    "lodash-es": "^4.17.22",
    "lowlight": "^3.0.0",
    "mailcheck": "^1.1.1",
    "pdfjs-dist": "4.5.136",
    "react": "^18.1.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "^18.1.0",
    "react-media-recorder": "^1.7.1",
    "react-router-dom": "^6.11.1",
    "react-select": "^5.7.0",
    "react-sortablejs": "^6.1.4",
    "recharts": "^2.15.2",
    "sortablejs": "^1.15.0",
    "tailwind-merge": "^3.3.1",
    "typia": "^12.1.1"
  },
  "devDependencies": {
    "@eslint/compat": "^1.1.1",
    "@eslint/js": "^9.6.0",
    "@tailwindcss/postcss": "^4.1.14",
    "@tailwindcss/typography": "^0.5.19",
    "@types/braintree-web": "^3.75.22",
    "@types/facebook-pixel": "^0.0.31",
    "@types/google.analytics": "^0.0.46",
    "@types/grecaptcha": "^3.0.4",
    "@types/gtag.js": "^0.0.20",
    "@types/jquery": "^3.5.16",
    "@types/jwplayer": "^8.28.1",
    "@types/mailcheck": "^1.1.33",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.26",
    "@types/react-dom": "^18.0.10",
    "@types/sortablejs": "^1.15.0",
    "@typia/unplugin": "^12.1.1",
    "@vitejs/plugin-react": "^4.4.0",
    "eslint": "^9.6.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.31.11",
    "globals": "^15.8.0",
    "lint-staged": "^15.0.0",
    "patch-package": "^8.0.0",
    "postcss": "^8.4.31",
    "postcss-preset-env": "^10.0.0",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "~1.77.0",
    "svgo": "^3.0.2",
    "tailwindcss": "^4.1.14",
    "ts-patch": "^3.3.0",
    "typescript": "~6.0",
    "typescript-eslint": "^8.0.0",
    "unplugin-auto-import": "^19.0.0",
    "vite": "^6.0.0",
    "vite-plugin-ruby": "^5.1.0"
  },
  "overrides": {
    "@tiptap/extension-blockquote": "$@tiptap/starter-kit",
    "@tiptap/extension-bold": "$@tiptap/starter-kit",
    "@tiptap/extension-bubble-menu": "$@tiptap/react",
    "@tiptap/extension-bullet-list": "$@tiptap/starter-kit",
    "@tiptap/extension-code-block": "$@tiptap/starter-kit",
    "@tiptap/extension-code": "$@tiptap/starter-kit",
    "@tiptap/extension-document": "$@tiptap/starter-kit",
    "@tiptap/extension-dropcursor": "$@tiptap/starter-kit",
    "@tiptap/extension-floating-menu": "$@tiptap/react",
    "@tiptap/extension-gapcursor": "$@tiptap/starter-kit",
    "@tiptap/extension-hard-break": "$@tiptap/starter-kit",
    "@tiptap/extension-history": "$@tiptap/starter-kit",
    "@tiptap/extension-horizontal-rule": "$@tiptap/starter-kit",
    "@tiptap/extension-italic": "$@tiptap/starter-kit",
    "@tiptap/extension-list-item": "$@tiptap/starter-kit",
    "@tiptap/extension-ordered-list": "$@tiptap/starter-kit",
    "@tiptap/extension-paragraph": "$@tiptap/starter-kit",
    "@tiptap/extension-strike": "$@tiptap/starter-kit",
    "@tiptap/extension-text": "$@tiptap/starter-kit",
    "csstype": "3.1.3"
  },
  "scripts": {
    "build": "npx vite build",
    "build:widget": "WIDGET_TARGET=gumroad npx vite build --config vite.config.widget.ts && WIDGET_TARGET=gumroad-embed npx vite build --config vite.config.widget.ts",
    "lint-fast": "DISABLE_TYPE_CHECKED=1 npx eslint",
    "setup": "bundle exec rails js:export",
    "postinstall": "patch-package && ts-patch install -s"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antiwork/gumroad.git"
  },
  "type": "module",
  "author": "Gumroad Developers",
  "browserslist": [
    "defaults and supports es6"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs}": "npm run lint-fast -- --max-warnings 0 --fix --no-warn-ignored",
    "*.{css,scss,md,json}": "prettier --write",
    "*.rb": "bundle exec rubocop --force-exclusion -a",
    "*.svg": "svgo --multipass"
  },
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  }
}
